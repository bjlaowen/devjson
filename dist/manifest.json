{
  "manifest_version": 3,
  "name": "DevJSON",
  "version": "1.0.0",
  "description": "JSON 格式化、Path 提取、Diff，以及 JSON 与 Go / Proto / TypeScript / Java / C# / Python 数据模型的快速互转",
  "action": {
    "default_title": "DevJSON",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}